# Copy to .env and adjust if needed
# SYS password for CLI helpers (set-vector-memory, etc.): must match the DB container SYS password.
# Default gvenzl compose: ORACLE_SYS_PASSWORD → container ORACLE_PASSWORD.
# Official Oracle Free image: often ORACLE_PWD in compose — set ORACLE_SYS_PASSWORD to the same value.
ORACLE_SYS_PASSWORD=PaperSearch_Sys_1
# Optional: Kaggle API (for import-kaggle) if not using ~/.kaggle/kaggle.json
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_CDB_SERVICE=FREE
ORACLE_PDB=FREEPDB1
ORACLE_VECTOR_MEMORY_SIZE=512M
ORACLE_APP_PASSWORD=PaperSearch_App_1

# Application → Oracle (matches docker-compose APP user by default)
PAPERSEARCH_ORACLE_USER=papersearch
PAPERSEARCH_ORACLE_PASSWORD=PaperSearch_App_1
PAPERSEARCH_ORACLE_DSN=localhost:1521/FREEPDB1

# Embeddings (must match VECTOR column dimension = 384)
PAPERSEARCH_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# API
PAPERSEARCH_HOST=0.0.0.0
PAPERSEARCH_PORT=8000
PAPERSEARCH_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Vector retrieval: use FETCH APPROXIMATE when HNSW index exists (Oracle AI Vector Search)
PAPERSEARCH_USE_APPROXIMATE_FETCH=true
